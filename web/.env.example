# ============================================================
# VibeFast — Variables de entorno
# Copia este archivo a .env.local y rellena los valores
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
# Encuentra estas keys en: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Resend (email) ---
# https://resend.com/api-keys
RESEND_API_KEY=

# --- PostHog (opcional, analytics) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- OAuth providers (Gmail receta, opcional) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
